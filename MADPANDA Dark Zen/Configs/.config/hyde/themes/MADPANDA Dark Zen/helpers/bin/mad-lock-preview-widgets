#!/usr/bin/env bash
set -uo pipefail

repo_root="${MAD_PROJECT_LINUX_REPO:-/home/leo/the-lab/project-linux/project-linux}"
config_home="${XDG_CONFIG_HOME:-$HOME/.config}"
runtime_root="${XDG_RUNTIME_DIR:-/tmp}/madpanda-lock-widgets"
preview_layout="${MAD_LOCK_WIDGET_PREVIEW_LAYOUT:-$config_home/hypr/hyprlock/MADPANDA-Dark-Zen-widgets-preview.conf}"
fallback_layout="$repo_root/themes/MADPANDA-Dark-Zen/hyprlock/MADPANDA-Dark-Zen-widgets-preview.conf"
preview_config="$runtime_root/hyprlock-preview.conf"
preview_grace="${MAD_LOCK_WIDGET_PREVIEW_GRACE:-0}"
dry_run=0

usage() {
    cat <<'EOF'
Usage: mad-lock-preview-widgets [--dry-run] [hyprlock args...]

Builds the lock-widget cache, then starts Hyprlock with the Dark Zen widget
preview layout. The active Dark Zen lock layout is not changed.

Set MAD_LOCK_WIDGET_PREVIEW_GRACE to override the default --grace 0.
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --dry-run)
            dry_run=1
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            break
            ;;
    esac
done

if [[ ! -r "$preview_layout" && -r "$fallback_layout" ]]; then
    preview_layout="$fallback_layout"
fi

widget_bin="${MAD_LOCK_WIDGETS_BIN:-}"
if [[ -z "$widget_bin" ]]; then
    widget_bin="$(command -v mad-lock-widgets 2>/dev/null || true)"
fi
if [[ -z "$widget_bin" && -x "${BASH_SOURCE[0]%/*}/mad-lock-widgets" ]]; then
    widget_bin="${BASH_SOURCE[0]%/*}/mad-lock-widgets"
fi

if [[ -n "$widget_bin" ]]; then
    "$widget_bin" prepare >/dev/null 2>&1 || true
fi

mkdir -p "$runtime_root"
{
    printf '# Generated by mad-lock-preview-widgets. Active Hyprlock config is not changed.\n'
    printf '$LAYOUT_PATH=%s\n' "$preview_layout"
    printf '$BACKGROUND_PATH = %s/hyde/wall.set.png\n' "${XDG_CACHE_HOME:-$HOME/.cache}"
    printf '$HYPRLOCK_BACKGROUND = %s/hyde/wallpapers/hyprlock.png\n' "${XDG_CACHE_HOME:-$HOME/.cache}"
    printf '$MPRIS_IMAGE = %s/hyde/landing/mpris.png\n' "${XDG_CACHE_HOME:-$HOME/.cache}"
    printf '$PROFILE_IMAGE = %s/hyde/landing/profile.png\n' "${XDG_CACHE_HOME:-$HOME/.cache}"
    printf '$BATTERY_ICON = battery.sh icon\n'
    printf 'source = %s/hypr/themes/colors.conf\n' "$config_home"
    printf '\n'
    printf 'general {\n'
    printf '    no_fade_in = true\n'
    printf '    grace = 0\n'
    printf '    disable_loading_bar = true\n'
    printf '    immediate_render = true\n'
    printf '    screencopy_mode = 0\n'
    printf '}\n'
    printf '\n'
    printf 'animations {\n'
    printf '    enabled = false\n'
    printf '}\n'
    printf '\n'
    printf 'background {\n'
    printf '    color = rgba(3, 0, 0, 0.95)\n'
    printf '}\n'
    printf '\n'
    printf 'source = %s\n' "$preview_layout"
} >"$preview_config"

if [[ "$dry_run" == "1" ]]; then
    printf 'layout=%s\n' "$preview_layout"
    printf 'config=%s\n' "$preview_config"
    printf 'widgetBin=%s\n' "${widget_bin:-missing}"
    printf 'command=hyprlock --config %q --immediate-render --no-fade-in --grace %q' "$preview_config" "$preview_grace"
    if [[ $# -gt 0 ]]; then
        printf ' %q' "$@"
    fi
    printf '\n'
    exit 0
fi

if [[ ! -r "$preview_layout" ]]; then
    printf 'mad-lock-preview-widgets: preview layout not found: %s\n' "$preview_layout" >&2
    exit 1
fi
if ! command -v hyprlock >/dev/null 2>&1; then
    printf 'mad-lock-preview-widgets: hyprlock is not installed\n' >&2
    exit 1
fi

exec hyprlock --config "$preview_config" --immediate-render --no-fade-in --grace "$preview_grace" "$@"
