#!/usr/bin/env bash
set -euo pipefail

theme_name="MADPANDA-Dark-Zen"
theme_label="MADPANDA Dark Zen"
state_root="${XDG_STATE_HOME:-$HOME/.local/state}/madpanda/plymouth"
state_file="$state_root/current.env"
dry_run="0"
install_package="0"
reboot_after="0"

usage() {
    cat <<'EOF'
Usage:
  mad-plymouth-theme status
  mad-plymouth-theme apply [--dry-run] [--install-package] [--reboot]
  mad-plymouth-theme rollback [--dry-run] [--reboot]

Applies or rolls back the MADPANDA Dark Zen Plymouth boot splash.
EOF
}

log() {
    printf '%s\n' "$*"
}

run() {
    if [[ "$dry_run" == "1" ]]; then
        printf '[dry-run]'
        printf ' %q' "$@"
        printf '\n'
    else
        "$@"
    fi
}

sudo_run() {
    run sudo -n "$@"
}

need_sudo() {
    [[ "$dry_run" == "1" ]] && return 0
    if ! sudo -n true >/dev/null 2>&1; then
        printf 'sudo -n is required for Plymouth boot changes.\n' >&2
        exit 1
    fi
}

script_dir() {
    local source="${BASH_SOURCE[0]:-$0}"
    cd "$(dirname "$source")" && pwd
}

repo_root_candidates() {
    [[ -n "${MAD_PROJECT_LINUX_REPO:-}" ]] && printf '%s\n' "$MAD_PROJECT_LINUX_REPO"
    printf '%s\n' \
        "$HOME/the-lab/project-linux/project-linux" \
        "$HOME/project-linux/project-linux"
}

theme_source_dir() {
    local repo candidate helper_dir
    [[ -n "${MAD_PLYMOUTH_THEME_SOURCE:-}" && -d "$MAD_PLYMOUTH_THEME_SOURCE" ]] && {
        printf '%s\n' "$MAD_PLYMOUTH_THEME_SOURCE"
        return 0
    }
    while IFS= read -r repo; do
        candidate="$repo/themes/MADPANDA-Dark-Zen/plymouth/$theme_name"
        [[ -d "$candidate" ]] && {
            printf '%s\n' "$candidate"
            return 0
        }
    done < <(repo_root_candidates)
    candidate="${XDG_CONFIG_HOME:-$HOME/.config}/hyde/themes/$theme_label/plymouth/$theme_name"
    [[ -d "$candidate" ]] && {
        printf '%s\n' "$candidate"
        return 0
    }
    helper_dir="$(script_dir)"
    candidate="$helper_dir/../plymouth/$theme_name"
    [[ -d "$candidate" ]] && {
        printf '%s\n' "$candidate"
        return 0
    }
    return 1
}

current_plymouth_theme() {
    if command -v plymouth-set-default-theme >/dev/null 2>&1; then
        plymouth-set-default-theme 2>/dev/null | head -n 1 || true
        return 0
    fi
    if [[ -r /etc/plymouth/plymouthd.conf ]]; then
        awk -F= '/^Theme=/{print $2; exit}' /etc/plymouth/plymouthd.conf
    fi
}

grub_cmdline_default() {
    local line
    line="$(grep -m1 '^GRUB_CMDLINE_LINUX_DEFAULT=' /etc/default/grub 2>/dev/null || true)"
    line="${line#GRUB_CMDLINE_LINUX_DEFAULT=}"
    printf '%s\n' "$line" | sed -e 's/^"//' -e 's/"$//' -e "s/^'//" -e "s/'$//"
}

boot_has_flags() {
    local cmdline
    cmdline="$(grub_cmdline_default)"
    [[ " $cmdline " == *" quiet "* && " $cmdline " == *" splash "* ]]
}

make_run_root() {
    local ts
    ts="$(date +%Y%m%dT%H%M%S%z)"
    printf '%s/%s\n' "$state_root" "$ts"
}

backup_path() {
    local path="$1"
    local run_root="$2"
    [[ -e "$path" || -L "$path" ]] || return 0
    run mkdir -p "$run_root/backups/$(dirname "${path#/}")"
    run sudo -n cp -a "$path" "$run_root/backups/${path#/}"
}

backup_boot_state() {
    local run_root="$1"
    run mkdir -p "$run_root/backups"
    backup_path /etc/default/grub "$run_root"
    backup_path /boot/grub/grub.cfg "$run_root"
    backup_path /etc/dracut.conf.d "$run_root"
    backup_path /etc/plymouth/plymouthd.conf "$run_root"
    if [[ "$dry_run" == "1" ]]; then
        printf '[dry-run] backup /boot/initramfs* and /boot/*initrd* to %q\n' "$run_root/backups/boot"
    else
        sudo -n mkdir -p "$run_root/backups/boot"
        find /boot -maxdepth 1 -type f \( -name 'initramfs*' -o -name '*initrd*' \) -print0 2>/dev/null |
            sudo -n xargs -0 -r cp -a -t "$run_root/backups/boot"
    fi
}

ensure_plymouth_package() {
    if command -v plymouth >/dev/null 2>&1 && command -v plymouth-set-default-theme >/dev/null 2>&1; then
        return 0
    fi
    if [[ "$dry_run" == "1" ]]; then
        if [[ "$install_package" == "1" ]]; then
            printf '[dry-run] sudo pacman -S --needed --noconfirm plymouth\n'
        else
            printf '[dry-run] Plymouth is missing; live apply would require --install-package or a prior package install.\n'
        fi
        return 0
    fi
    if [[ "$install_package" != "1" ]]; then
        printf 'Plymouth is not installed. Re-run with --install-package or install package plymouth first.\n' >&2
        exit 1
    fi
    if ! command -v pacman >/dev/null 2>&1; then
        printf 'pacman is required to install Plymouth on this Arch/Endeavour system.\n' >&2
        exit 1
    fi
    sudo_run pacman -S --needed --noconfirm plymouth
}

write_dracut_dropin() {
    local file="/etc/dracut.conf.d/90-madpanda-plymouth.conf"
    if [[ "$dry_run" == "1" ]]; then
        printf '[dry-run] write %q with add_dracutmodules+= plymouth\n' "$file"
        return 0
    fi
    printf 'add_dracutmodules+=" plymouth "\n' | sudo -n tee "$file" >/dev/null
}

ensure_grub_flags() {
    local file="/etc/default/grub"
    local current next flag
    current="$(grub_cmdline_default)"
    next="$current"
    for flag in quiet splash; do
        if [[ " $next " != *" $flag "* ]]; then
            next="${next:+$next }$flag"
        fi
    done
    [[ "$next" == "$current" ]] && return 0
    if [[ "$dry_run" == "1" ]]; then
        printf '[dry-run] update GRUB_CMDLINE_LINUX_DEFAULT in %q to include quiet splash\n' "$file"
        printf '[dry-run] old=%q\n' "$current"
        printf '[dry-run] new=%q\n' "$next"
        return 0
    fi
    sudo -n sed -i "s|^GRUB_CMDLINE_LINUX_DEFAULT=.*|GRUB_CMDLINE_LINUX_DEFAULT=\"$next\"|" "$file"
}

rebuild_boot() {
    sudo_run dracut-rebuild
    sudo_run grub-mkconfig -o /boot/grub/grub.cfg
}

write_state() {
    local run_root="$1"
    local previous="$2"
    [[ "$dry_run" == "1" ]] && {
        printf '[dry-run] write state file %q\n' "$state_file"
        return 0
    }
    mkdir -p "$state_root"
    {
        printf 'MAD_PLYMOUTH_THEME=%q\n' "$theme_name"
        printf 'MAD_PLYMOUTH_PREVIOUS_THEME=%q\n' "$previous"
        printf 'MAD_PLYMOUTH_RUN_ROOT=%q\n' "$run_root"
        printf 'MAD_PLYMOUTH_APPLIED_AT=%q\n' "$(date --iso-8601=seconds)"
    } >"$state_file"
}

apply_theme() {
    local source_dir live_dir previous run_root
    source_dir="$(theme_source_dir)" || {
        printf 'Could not find packaged Plymouth theme for %s.\n' "$theme_label" >&2
        exit 1
    }
    live_dir="/usr/share/plymouth/themes/$theme_name"
    previous="$(current_plymouth_theme)"
    run_root="$(make_run_root)"

    need_sudo
    ensure_plymouth_package
    backup_boot_state "$run_root"
    sudo_run install -d -m 0755 "$live_dir"
    sudo_run rsync -a --delete "$source_dir/" "$live_dir/"
    sudo_run plymouth-set-default-theme "$theme_name"
    write_dracut_dropin
    ensure_grub_flags
    rebuild_boot
    write_state "$run_root" "$previous"
    if [[ "$dry_run" == "1" ]]; then
        log "Dry-run complete for $theme_label Plymouth apply."
        log "Backups would be written under: $run_root/backups"
        return 0
    fi
    log "Applied $theme_label Plymouth theme."
    log "Backups: $run_root/backups"
    log "Rollback: mad-plymouth-theme rollback"
    if [[ "$reboot_after" == "1" ]]; then
        sudo_run reboot
    fi
}

restore_if_exists() {
    local backup="$1"
    local target="$2"
    [[ -e "$backup" || -L "$backup" ]] || return 0
    sudo_run cp -a "$backup" "$target"
}

rollback_theme() {
    local run_root previous
    if [[ -r "$state_file" ]]; then
        # shellcheck disable=SC1090
        . "$state_file"
        run_root="${MAD_PLYMOUTH_RUN_ROOT:-}"
        previous="${MAD_PLYMOUTH_PREVIOUS_THEME:-}"
    else
        printf 'No Plymouth state file found at %s.\n' "$state_file" >&2
        exit 1
    fi
    [[ -n "$run_root" ]] || {
        printf 'Plymouth rollback state is missing backup path.\n' >&2
        exit 1
    }
    need_sudo
    restore_if_exists "$run_root/backups/etc/default/grub" /etc/default/grub
    restore_if_exists "$run_root/backups/boot/grub/grub.cfg" /boot/grub/grub.cfg
    if [[ -d "$run_root/backups/etc/dracut.conf.d" ]]; then
        sudo_run rsync -a --delete "$run_root/backups/etc/dracut.conf.d/" /etc/dracut.conf.d/
    else
        sudo_run rm -f /etc/dracut.conf.d/90-madpanda-plymouth.conf
    fi
    restore_if_exists "$run_root/backups/etc/plymouth/plymouthd.conf" /etc/plymouth/plymouthd.conf
    if [[ -n "$previous" && "$previous" != "$theme_name" ]] && command -v plymouth-set-default-theme >/dev/null 2>&1; then
        sudo_run plymouth-set-default-theme "$previous"
    fi
    rebuild_boot
    run rm -f "$state_file"
    log "Rolled back $theme_label Plymouth boot changes."
    log "Reboot to validate the restored boot splash."
    if [[ "$reboot_after" == "1" ]]; then
        sudo_run reboot
    fi
}

status_theme() {
    local source_dir=""
    source_dir="$(theme_source_dir 2>/dev/null || true)"
    printf 'theme=%s\n' "$theme_name"
    printf 'sourceDir=%s\n' "$source_dir"
    printf 'sourcePresent=%s\n' "$([[ -n "$source_dir" ]] && printf true || printf false)"
    printf 'plymouthInstalled=%s\n' "$(command -v plymouth >/dev/null 2>&1 && printf true || printf false)"
    printf 'defaultTheme=%s\n' "$(current_plymouth_theme)"
    printf 'liveThemePresent=%s\n' "$([[ -d "/usr/share/plymouth/themes/$theme_name" ]] && printf true || printf false)"
    printf 'dracutDropinPresent=%s\n' "$([[ -r /etc/dracut.conf.d/90-madpanda-plymouth.conf ]] && printf true || printf false)"
    printf 'grubQuietSplash=%s\n' "$(boot_has_flags && printf true || printf false)"
    printf 'stateFile=%s\n' "$state_file"
    printf 'statePresent=%s\n' "$([[ -r "$state_file" ]] && printf true || printf false)"
}

cmd="${1:-status}"
shift || true
while (($#)); do
    case "$1" in
        --dry-run) dry_run="1" ;;
        --install-package) install_package="1" ;;
        --reboot) reboot_after="1" ;;
        -h|--help|help) usage; exit 0 ;;
        *) usage >&2; exit 2 ;;
    esac
    shift
done

case "$cmd" in
    status) status_theme ;;
    apply) apply_theme ;;
    rollback) rollback_theme ;;
    -h|--help|help) usage ;;
    *) usage >&2; exit 2 ;;
esac
