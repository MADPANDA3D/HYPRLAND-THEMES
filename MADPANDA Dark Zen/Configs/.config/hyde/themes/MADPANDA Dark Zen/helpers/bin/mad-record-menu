#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
helper="${MAD_RECORD_HELPER:-$script_dir/mad-record-active-monitor}"
[[ -x "$helper" ]] || helper="${XDG_BIN_HOME:-$HOME/.local/bin}/mad-record-active-monitor"
[[ -x "$helper" ]] || helper="mad-record-active-monitor"

case "${1:-}" in
    -h|--help|help)
        printf 'Usage: mad-record-menu\n'
        printf 'Opens the Dark Zen recording mode menu.\n'
        exit 0
        ;;
esac

choices=$'Smart follow toggle\nFixed active monitor toggle\nCreator mode toggle\nFocused window toggle\nRegion selection toggle\nPortal picker toggle\nStop current recording'

if ! command -v rofi >/dev/null 2>&1; then
    exec "$helper" active-monitor
fi

selection="$(printf '%s\n' "$choices" | rofi -dmenu -i -p 'Recording')"
case "$selection" in
    "Smart follow toggle") exec "$helper" smart ;;
    "Fixed active monitor toggle") exec "$helper" fixed ;;
    "Creator mode toggle") exec "$helper" creator ;;
    "Focused window toggle") exec "$helper" focused ;;
    "Region selection toggle") exec "$helper" region ;;
    "Portal picker toggle") exec "$helper" portal ;;
    "Stop current recording") exec "$helper" stop ;;
    *) exit 0 ;;
esac
