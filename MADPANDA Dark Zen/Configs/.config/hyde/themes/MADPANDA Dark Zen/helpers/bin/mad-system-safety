#!/usr/bin/env bash
set -euo pipefail

state_root="${XDG_STATE_HOME:-$HOME/.local/state}/madpanda/system-safety"
dry_run="0"
output_dir=""

usage() {
    cat <<'EOF'
Usage:
  mad-system-safety status
  mad-system-safety configure-timeshift [--dry-run]
  mad-system-safety snapshot [--dry-run] [label...]
  mad-system-safety export-manifest [--dry-run] [--output DIR]
  mad-system-safety restore-plan [--manifest DIR]

Local-first safety tools for MADPANDA workstation/laptop rebuilds.
This helper does not format disks or configure external SATA backups.
EOF
}

run_id() {
    date +%Y%m%dT%H%M%S%z
}

log() {
    printf '%s\n' "$*"
}

run() {
    if [[ "$dry_run" == "1" ]]; then
        printf '[dry-run]'
        printf ' %q' "$@"
        printf '\n'
    else
        "$@"
    fi
}

sudo_run() {
    run sudo -n "$@"
}

need_sudo() {
    [[ "$dry_run" == "1" ]] && return 0
    if ! sudo -n true >/dev/null 2>&1; then
        printf 'sudo -n is required for Timeshift safety operations.\n' >&2
        exit 1
    fi
}

root_uuid() {
    findmnt -no UUID / | head -n 1
}

root_fstype() {
    findmnt -no FSTYPE / | head -n 1
}

timeshift_cfg() {
    for cfg in /etc/timeshift/timeshift.json /etc/timeshift/default.json; do
        [[ -r "$cfg" ]] && printf '%s\n' "$cfg"
    done
}

timeshift_btrfs_mode() {
    local cfg="/etc/timeshift/timeshift.json"
    [[ -r "$cfg" ]] || cfg="/etc/timeshift/default.json"
    [[ -r "$cfg" ]] || {
        printf 'unknown\n'
        return 0
    }
    jq -r '.btrfs_mode // "unknown"' "$cfg" 2>/dev/null || printf 'unknown\n'
}

latest_manifest_dir() {
    find "$state_root/manifests" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort | tail -n 1
}

status_cmd() {
    printf 'timeshiftInstalled=%s\n' "$(command -v timeshift >/dev/null 2>&1 && printf true || printf false)"
    printf 'rootFstype=%s\n' "$(root_fstype)"
    printf 'rootUuid=%s\n' "$(root_uuid)"
    printf 'timeshiftBtrfsMode=%s\n' "$(timeshift_btrfs_mode)"
    printf 'stateRoot=%s\n' "$state_root"
    printf 'latestManifest=%s\n' "$(latest_manifest_dir)"
    if command -v timeshift >/dev/null 2>&1; then
        sudo -n timeshift --list-snapshots 2>/dev/null | sed 's/^/timeshift: /' || true
    fi
}

configure_timeshift() {
    local uuid backup_root cfg tmp rid

    [[ "$(root_fstype)" == "btrfs" ]] || {
        printf 'Root filesystem is not Btrfs; refusing Timeshift Btrfs config.\n' >&2
        exit 1
    }
    uuid="$(root_uuid)"
    [[ -n "$uuid" ]] || {
        printf 'Could not determine root Btrfs UUID.\n' >&2
        exit 1
    }

    need_sudo
    rid="$(run_id)"
    backup_root="$state_root/timeshift-config-backups/$rid"
    run mkdir -p "$backup_root"

    while IFS= read -r cfg; do
        [[ -n "$cfg" ]] || continue
        run sudo -n cp -a "$cfg" "$backup_root/${cfg##*/}"
        if [[ "$dry_run" == "1" ]]; then
            printf '[dry-run] set %q backup_device_uuid=%q btrfs_mode=true do_first_run=false schedules=false\n' "$cfg" "$uuid"
            continue
        fi
        tmp="$(mktemp)"
        sudo -n jq --arg uuid "$uuid" '
          .backup_device_uuid = $uuid
          | .do_first_run = "false"
          | .btrfs_mode = "true"
          | .include_btrfs_home = "false"
          | .schedule_monthly = "false"
          | .schedule_weekly = "false"
          | .schedule_daily = "false"
          | .schedule_hourly = "false"
          | .schedule_boot = "false"
        ' "$cfg" >"$tmp"
        sudo -n install -m 0644 "$tmp" "$cfg"
        rm -f "$tmp"
    done < <(timeshift_cfg)

    log "Timeshift Btrfs config prepared."
    log "Config backup: $backup_root"
}

snapshot_cmd() {
    local label
    label="${*:-manual pre-change}"
    need_sudo
    if [[ "$(root_fstype)" != "btrfs" ]]; then
        printf 'Root filesystem is not Btrfs; refusing snapshot.\n' >&2
        exit 1
    fi
    if ! command -v timeshift >/dev/null 2>&1; then
        printf 'Timeshift is not installed.\n' >&2
        exit 1
    fi
    sudo_run timeshift --create --btrfs --comments "MADPANDA pre-change: $label" --tags O --scripted --yes
}

package_with_versions() {
    local list_cmd="$1"
    while IFS= read -r pkg; do
        [[ -n "$pkg" ]] || continue
        pacman -Q "$pkg" 2>/dev/null || true
    done < <($list_cmd)
}

export_manifest() {
    local out rid features
    rid="$(run_id)"
    out="${output_dir:-$state_root/manifests/$rid}"
    if [[ "$dry_run" == "1" ]]; then
        printf '[dry-run] mkdir -p %q\n' "$out"
        printf '[dry-run] export pacman, AUR, services, Dark Zen feature state, and restore plan files\n'
        return 0
    fi

    mkdir -p "$out"
    pacman -Qqe | sort >"$out/pacman-explicit.txt"
    package_with_versions "pacman -Qqe" | sort >"$out/pacman-explicit-with-versions.txt"
    pacman -Qqm | sort >"$out/pacman-foreign.txt" || true
    package_with_versions "pacman -Qqm" | sort >"$out/pacman-foreign-with-versions.txt"
    systemctl list-unit-files --state=enabled --no-pager --no-legend >"$out/enabled-system-units.txt"
    systemctl --user list-unit-files --state=enabled --no-pager --no-legend >"$out/enabled-user-units.txt" 2>/dev/null || true
    if command -v mad-theme-pack >/dev/null 2>&1; then
        mad-theme-pack status "MADPANDA Dark Zen" >"$out/dark-zen-status.txt" 2>&1 || true
    fi
    features="${XDG_CONFIG_HOME:-$HOME/.config}/madpanda/themes/MADPANDA-Dark-Zen/features.env"
    [[ -r "$features" ]] && cp -a "$features" "$out/dark-zen-features.env"
    {
        printf '# MADPANDA package restore plan\n'
        printf '# Generated: %s\n\n' "$(date --iso-8601=seconds)"
        printf '# Official repo packages:\n'
        printf 'xargs -a %q sudo pacman -S --needed --noconfirm\n\n' "$out/pacman-explicit.txt"
        printf '# AUR/foreign packages, review first:\n'
        printf 'xargs -a %q yay -S --needed --noconfirm\n\n' "$out/pacman-foreign.txt"
        printf '# Services are recorded for review in enabled-system-units.txt and enabled-user-units.txt.\n'
        printf '# Reapply Dark Zen after HyDE is installed/imported:\n'
        printf 'mad-theme-pack apply "MADPANDA Dark Zen"\n'
    } >"$out/restore-plan.sh"
    chmod 0755 "$out/restore-plan.sh"
    log "Manifest exported: $out"
}

restore_plan() {
    local manifest="$output_dir"
    [[ -n "$manifest" ]] || manifest="$(latest_manifest_dir)"
    [[ -n "$manifest" && -d "$manifest" ]] || {
        printf 'No manifest directory found. Run mad-system-safety export-manifest first.\n' >&2
        exit 1
    }
    printf 'manifest=%s\n' "$manifest"
    printf 'repoPackages=%s\n' "$manifest/pacman-explicit.txt"
    printf 'foreignPackages=%s\n' "$manifest/pacman-foreign.txt"
    printf 'restorePlan=%s\n' "$manifest/restore-plan.sh"
    [[ -r "$manifest/restore-plan.sh" ]] && sed -n '1,120p' "$manifest/restore-plan.sh"
}

cmd="${1:-status}"
shift || true
while (($#)); do
    case "$1" in
        --dry-run) dry_run="1" ;;
        --output|--manifest)
            shift
            output_dir="${1:-}"
            ;;
        -h|--help|help)
            usage
            exit 0
            ;;
        *)
            break
            ;;
    esac
    shift || true
done

case "$cmd" in
    status) status_cmd ;;
    configure-timeshift) configure_timeshift ;;
    snapshot) snapshot_cmd "$@" ;;
    export-manifest) export_manifest ;;
    restore-plan) restore_plan ;;
    -h|--help|help) usage ;;
    *) usage >&2; exit 2 ;;
esac
