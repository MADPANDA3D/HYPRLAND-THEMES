#!/usr/bin/env bash
set -euo pipefail

if pgrep -x rofi >/dev/null 2>&1; then
    pkill -x rofi
    exit 0
fi

LIB_DIR="${LIB_DIR:-$HOME/.local/lib}"

custom_rows="$(
    cat <<'EOF'
 MADPANDA Daily                ::: ::: MADPANDA Daily
SUPER + Q            > Terminal ::: :::
SUPER + W            > Dictation start/stop ::: :::
SUPER + E            > Google Chrome ::: :::
SUPER + M            > Toggle microphone mute ::: :::
SUPER + R            > Smart-follow recording ::: :::
SUPER CTRL + R       > Fixed monitor recording ::: :::
SUPER SHIFT + R      > Creator recording with camera ::: :::
SUPER ALT + R        > Screen recording modes ::: :::
SUPER + A            > Hyprexpo workspace overview ::: :::
SUPER + S            > Active tile screenshot ::: :::
SUPER SHIFT + S      > Region screenshot ::: :::
Print                > Active monitor screenshot ::: :::
SUPER + T            > Scratchpad / special workspace ::: :::
SUPER + D            > Dolphin ::: :::
SUPER + F            > Keybind cheat sheet ::: :::
SUPER + slash        > Keybind cheat sheet ::: :::
SUPER + Z            > Visual Studio Code ::: :::
SUPER + X            > Dark Zen widget drawer ::: :::
SUPER + C            > Themed close window ::: :::
SUPER + SPACE        > App launcher ::: :::
SUPER + L            > Lock screen ::: :::
 Workspace Summary             ::: ::: Workspace Summary
SUPER + 1..9         > Switch workspaces ::: :::
SUPER SHIFT + 1..9   > Move window to workspace ::: :::
SUPER + KP_1..KP_9   > Switch workspaces with numpad ::: :::
SUPER SHIFT + KP_*   > Move window with numpad ::: :::
SUPER + arrows       > Move focus ::: :::
SUPER SHIFT + arrows > Move window ::: :::
SUPER ALT + arrows   > Resize window ::: :::
 Full HyDE List                ::: ::: Full HyDE List
EOF
)"

hyde_rows=""
if [[ -n "${LIB_DIR:-}" && -x "${LIB_DIR}/hyde/keybinds/hint-hyprland.py" ]]; then
    kb_cache="${XDG_RUNTIME_DIR:-/tmp}/hyde/keybinds_hint.rofi"
    if [[ -r "$kb_cache" ]]; then
        hyde_rows="$(cat "$kb_cache" 2>/dev/null || true)"
    fi
    if [[ -z "$hyde_rows" ]]; then
        hyde_rows="$("${LIB_DIR}/hyde/keybinds/hint-hyprland.py" --format rofi 2>/dev/null || true)"
    fi
fi

rows="$custom_rows"
if [[ -n "$hyde_rows" ]]; then
    rows="$custom_rows"$'\n'"$hyde_rows"
fi

if ! command -v rofi >/dev/null 2>&1; then
    printf '%s\n' "$rows"
    exit 0
fi

hypr_border=${hypr_border:-$(hyprctl -j getoption decoration:rounding 2>/dev/null | jq '.int' 2>/dev/null || echo 10)}
hypr_width=${hypr_width:-$(hyprctl -j getoption general:border_size 2>/dev/null | jq '.int' 2>/dev/null || echo 2)}
wind_border=$((hypr_border * 3 / 2))
elem_border=$([ "$hypr_border" -eq 0 ] && echo "5" || echo "$hypr_border")
kb_hint_width="${ROFI_KEYBIND_HINT_WIDTH:-40em}"
kb_hint_height="${ROFI_KEYBIND_HINT_HEIGHT:-40em}"
kb_hint_line="${ROFI_KEYBIND_HINT_LINE:-16}"
r_override="window {height: ${kb_hint_height}; width: ${kb_hint_width}; border: ${hypr_width}px; border-radius: ${wind_border}px;} entry {border-radius: ${elem_border}px;} element {border-radius: ${elem_border}px;} listview { lines: ${kb_hint_line}; }"
font_scale="${ROFI_KEYBIND_HINT_SCALE:-}"
if [[ -z "$font_scale" ]]; then
    font_scale="$(gsettings get org.gnome.desktop.interface font-name 2>/dev/null | awk '{gsub(/'\''/,""); print $NF}' || true)"
fi
[[ $font_scale =~ ^[0-9]+$ ]] || font_scale=${ROFI_SCALE:-10}
font_name="${ROFI_KEYBIND_HINT_FONT:-${ROFI_FONT:-}}"
font_override="* {font: \"${font_name:-JetBrainsMono Nerd Font} $font_scale\";}"
icon_theme="$(gsettings get org.gnome.desktop.interface icon-theme 2>/dev/null | sed "s/'//g" || true)"
icon_override="configuration {icon-theme: \"${icon_theme:-Papirus-Dark}\";}"

selected="$(
    printf '%s\n' "$rows" |
        rofi -dmenu \
            -i \
            -p " Keybinds \t\tﴕ Description" \
            -display-columns 1 \
            -display-column-separator ":::" \
            -theme-str "entry { placeholder: \"\t⌨️ Keybindings \";}" \
            -theme-str "$font_override" \
            -theme-str "$r_override" \
            -theme-str "$icon_override" \
            -theme "${ROFI_KEYBIND_HINT_STYLE:-clipboard}" |
        sed 's/.*\s*//'
)"

[[ -n "$selected" ]] || exit 0

dispatch="$(awk -F ':::' '{print $2}' <<< "$selected" | xargs)"
arg="$(awk -F ':::' '{print $3}' <<< "$selected" | xargs)"
repeat="$(awk -F ':::' '{print $4}' <<< "$selected" | xargs)"

run_dispatch() {
    case "$(eval "hyprctl dispatch '$dispatch' '$arg'")" in
        *"Not enough arguments"*) exec "$0" ;;
    esac
}

if [[ -n "$dispatch" && "$(wc -l <<< "$dispatch")" -eq 1 ]]; then
    if [[ "$repeat" == repeat ]]; then
        while true; do
            repeat_command="$(printf '%s\n' "Repeat" | rofi -dmenu -no-custom -p - "[Enter] repeat; [ESC] exit" -theme "notification")"
            [[ "$repeat_command" == "Repeat" ]] || exit 0
            run_dispatch
        done
    else
        run_dispatch
    fi
fi
