#!/usr/bin/env bash
set -euo pipefail

state_file="${XDG_STATE_HOME:-$HOME/.local/state}/hyde/staterc"
theme_root="${XDG_CONFIG_HOME:-$HOME/.config}/hyde/themes"
log_base="${MAD_THEME_SAFE_LOG_BASE:-${XDG_STATE_HOME:-$HOME/.local/state}/madpanda/runs}"
known_good="${MAD_THEME_SAFE_KNOWN_GOOD:-Catppuccin Mocha}"
blocked_themes="${MAD_THEME_SAFE_BLOCKLIST:-Material Sakura}"

usage() {
    cat <<'EOF'
Usage:
  mad-theme-safe current
  mad-theme-safe list
  mad-theme-safe list --all
  mad-theme-safe blocked
  mad-theme-safe select
  mad-theme-safe set "Theme Name"
  mad-theme-safe next
  mad-theme-safe previous
  mad-theme-safe recover
  mad-theme-safe notify-current

This wraps HyDE theme switching with backups and logs. Use it from inside the
graphical Hyprland session for live theme changes.
EOF
}

current_theme() {
    if [[ -r "$state_file" ]]; then
        sed -n 's/^HYDE_THEME="\{0,1\}\([^"]*\)"\{0,1\}$/\1/p' "$state_file" | tail -n 1
    fi
}

theme_slug() {
    printf '%s' "$1" | tr ' ' '-'
}

theme_pack_manifest_exists() {
    local target="$1"
    [[ -r "$theme_root/$target/theme.json" ]]
}

is_blocked_theme() {
    local target="$1"
    local item
    IFS=',' read -ra items <<<"$blocked_themes"
    for item in "${items[@]}"; do
        item="${item#"${item%%[![:space:]]*}"}"
        item="${item%"${item##*[![:space:]]}"}"
        [[ "$target" == "$item" ]] && return 0
    done
    return 1
}

list_blocked_themes() {
    local item
    IFS=',' read -ra items <<<"$blocked_themes"
    for item in "${items[@]}"; do
        item="${item#"${item%%[![:space:]]*}"}"
        item="${item%"${item##*[![:space:]]}"}"
        [[ -n "$item" ]] && printf '%s\n' "$item"
    done
}

list_themes() {
    local include_blocked="${1:-}"
    local dir sort
    while IFS= read -r -d '' dir; do
        if [[ "$include_blocked" != "--all" ]] && is_blocked_theme "${dir##*/}"; then
            continue
        fi
        sort="0"
        [[ -r "$dir/.sort" ]] && sort="$(head -n 1 "$dir/.sort")"
        printf '%s\t%s\n' "$sort" "${dir##*/}"
    done < <(find "$theme_root" -mindepth 1 -maxdepth 1 -type d -print0) |
        sort -n -k 1,1 -k 2,2 |
        cut -f2-
}

theme_exists() {
    local target="$1"
    [[ -d "$theme_root/$target" ]]
}

require_graphical_session() {
    if [[ -z "${HYPRLAND_INSTANCE_SIGNATURE:-}" || -z "${WAYLAND_DISPLAY:-}" ]]; then
        echo "Refusing live switch: this shell is not inside the Hyprland Wayland session." >&2
        echo "From TTY, use: mad-theme-safe recover" >&2
        exit 2
    fi
}

make_run_root() {
    local target="$1"
    local safe_target
    safe_target="$(printf '%s' "$target" | tr ' /' '__' | tr -cd '[:alnum:]_.-')"
    local ts
    ts="$(date +%Y%m%dT%H%M%S%z)"
    printf '%s/hyde-theme-switch-%s-%s\n' "$log_base" "$ts" "$safe_target"
}

copy_if_exists() {
    local src="$1"
    local dst="$2"
    if [[ -e "$src" || -L "$src" ]]; then
        mkdir -p "$(dirname "$dst")"
        cp -a "$src" "$dst"
    fi
}

snapshot_state() {
    local root="$1"
    local label="$2"
    mkdir -p "$root/$label/live" "$root/$label/system"
    copy_if_exists "$state_file" "$root/$label/live/staterc"
    copy_if_exists "${XDG_CONFIG_HOME:-$HOME/.config}/hypr/themes/theme.conf" "$root/$label/live/hypr-theme.conf"
    copy_if_exists "${XDG_CONFIG_HOME:-$HOME/.config}/hypr/themes/colors.conf" "$root/$label/live/hypr-colors.conf"
    copy_if_exists "${XDG_CONFIG_HOME:-$HOME/.config}/waybar/theme.css" "$root/$label/live/waybar-theme.css"
    copy_if_exists "${XDG_CONFIG_HOME:-$HOME/.config}/waybar/style.css" "$root/$label/live/waybar-style.css"
    copy_if_exists "${XDG_CONFIG_HOME:-$HOME/.config}/kitty/theme.conf" "$root/$label/live/kitty-theme.conf"
    copy_if_exists "${XDG_CONFIG_HOME:-$HOME/.config}/rofi/theme.rasi" "$root/$label/live/rofi-theme.rasi"
    copy_if_exists "${XDG_CONFIG_HOME:-$HOME/.config}/gtk-3.0/settings.ini" "$root/$label/live/gtk3-settings.ini"
    copy_if_exists "${XDG_CONFIG_HOME:-$HOME/.config}/qt5ct/qt5ct.conf" "$root/$label/live/qt5ct.conf"
    copy_if_exists "${XDG_CONFIG_HOME:-$HOME/.config}/qt6ct/qt6ct.conf" "$root/$label/live/qt6ct.conf"
    copy_if_exists "$HOME/.gtkrc-2.0" "$root/$label/live/gtkrc-2.0"
    copy_if_exists "$HOME/.Xresources" "$root/$label/live/Xresources"

    hyprctl configerrors >"$root/$label/system/hyprctl-configerrors.txt" 2>&1 || true
    pgrep -af 'Hyprland|waybar|awww|dunst|swaync|hyprsunset|hypridle' >"$root/$label/system/processes.txt" 2>&1 || true
}

set_theme() {
    local target="$1"
    require_graphical_session
    if ! theme_exists "$target"; then
        echo "Theme not found: $target" >&2
        echo "Available themes:" >&2
        list_themes >&2
        exit 1
    fi
    if is_blocked_theme "$target" && [[ "${MAD_THEME_SAFE_ALLOW_BLOCKED:-0}" != "1" ]]; then
        echo "Blocked theme: $target" >&2
        echo "Reason: this theme is confirmed to destabilize this HyDE/Waybar session." >&2
        echo "To recover: mad-theme-safe recover" >&2
        exit 3
    fi

    local before root
    before="$(current_theme)"
    root="$(make_run_root "$target")"
    mkdir -p "$root/logs"
    {
        printf 'started_at=%s\n' "$(date --iso-8601=seconds)"
        printf 'before_theme=%s\n' "${before:-unknown}"
        printf 'target_theme=%s\n' "$target"
    } >"$root/summary.env"

    snapshot_state "$root" before
    hyde-shell theme.switch -q -s "$target" >"$root/logs/hyde-theme-switch.log" 2>&1
    if command -v mad-theme-runtime >/dev/null 2>&1; then
        mad-theme-runtime reconcile >"$root/logs/mad-theme-runtime.log" 2>&1 || true
    else
        if command -v mad-rgb-theme >/dev/null 2>&1; then
            MAD_RGB_THEME_LOG_ROOT="$root/rgb" mad-rgb-theme apply "$target" >"$root/logs/mad-rgb-theme.log" 2>&1 || true
        fi
        if command -v mad-theme-pack >/dev/null 2>&1; then
            if theme_pack_manifest_exists "$target"; then
                MAD_THEME_PACK_BACKUP_ROOT="$root/theme-pack" mad-theme-pack apply "$target" >"$root/logs/mad-theme-pack.log" 2>&1 || true
            else
                MAD_THEME_PACK_BACKUP_ROOT="$root/theme-pack" mad-theme-pack clear-overrides >"$root/logs/mad-theme-pack-clear.log" 2>&1 || true
            fi
        fi
    fi
    snapshot_state "$root" after
    coredumpctl list --since "$(date --date='2 minutes ago' '+%F %T')" --no-pager >"$root/logs/coredumpctl-recent.txt" 2>&1 || true
    {
        printf 'finished_at=%s\n' "$(date --iso-8601=seconds)"
        printf 'after_theme=%s\n' "$(current_theme)"
        printf 'log_root=%s\n' "$root"
    } >>"$root/summary.env"

    echo "Theme switched: ${before:-unknown} -> $(current_theme)"
    echo "Evidence: $root"
}

select_theme() {
    require_graphical_session
    local selected
    selected="$(list_themes | rofi -dmenu -i -p 'Theme')" || exit 0
    [[ -n "$selected" ]] || exit 0
    set_theme "$selected"
}

relative_theme() {
    local direction="$1"
    local current target count index next_index
    mapfile -t themes < <(list_themes)
    current="$(current_theme)"
    count="${#themes[@]}"
    [[ "$count" -gt 0 ]] || exit 1
    index=0
    for i in "${!themes[@]}"; do
        if [[ "${themes[$i]}" == "$current" ]]; then
            index="$i"
            break
        fi
    done
    if [[ "$direction" == "next" ]]; then
        next_index=$(((index + 1) % count))
    else
        next_index=$(((index + count - 1) % count))
    fi
    target="${themes[$next_index]}"
    set_theme "$target"
}

recover_theme() {
    if [[ -n "${HYPRLAND_INSTANCE_SIGNATURE:-}" && -n "${WAYLAND_DISPLAY:-}" ]]; then
        set_theme "$known_good"
        exit 0
    fi

    local root tmp
    root="$(make_run_root "offline-recover-$known_good")"
    mkdir -p "$root/logs"
    copy_if_exists "$state_file" "$root/staterc.before"
    tmp="$(mktemp)"
    if [[ -r "$state_file" ]] && grep -q '^HYDE_THEME=' "$state_file"; then
        awk -v theme="$known_good" '
            /^HYDE_THEME=/ { print "HYDE_THEME=\"" theme "\""; next }
            { print }
        ' "$state_file" >"$tmp"
    else
        [[ -r "$state_file" ]] && cat "$state_file" >"$tmp"
        printf 'HYDE_THEME="%s"\n' "$known_good" >>"$tmp"
    fi
    cp "$tmp" "$state_file"
    rm -f "$tmp"
    copy_if_exists "$state_file" "$root/staterc.after"
    echo "Offline recovery set HYDE_THEME to $known_good."
    echo "Reboot or log back into Hyprland so HyDE applies it."
    echo "Evidence: $root"
}

notify_current() {
    local current
    current="$(current_theme)"
    if command -v notify-send >/dev/null 2>&1; then
        notify-send "HyDE theme" "${current:-unknown}"
    else
        printf '%s\n' "${current:-unknown}"
    fi
}

case "${1:-}" in
    current)
        current_theme
        ;;
    list)
        list_themes "${2:-}"
        ;;
    blocked)
        list_blocked_themes
        ;;
    select)
        select_theme
        ;;
    set)
        shift
        [[ $# -gt 0 ]] || { usage; exit 1; }
        set_theme "$*"
        ;;
    next)
        relative_theme next
        ;;
    previous|prev)
        relative_theme previous
        ;;
    recover)
        recover_theme
        ;;
    notify-current)
        notify_current
        ;;
    -h|--help|help|'')
        usage
        ;;
    *)
        usage
        exit 1
        ;;
esac
