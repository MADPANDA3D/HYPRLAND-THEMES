{
  "manifest_version": 3,
  "name": "MADPANDA Pandora Media Bridge",
  "version": "0.1.7",
  "description": "Expose Pandora now-playing artwork and metadata to Dark Zen local widgets.",
  "key": "",
  "permissions": [
    "nativeMessaging",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "*://pandora.com/*",
    "*://*.pandora.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://pandora.com/*",
        "*://*.pandora.com/*"
      ],
      "js": [
        "content-pandora.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "background": {
    "service_worker": "service-worker.js"
  }
}
